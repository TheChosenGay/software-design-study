e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 \u2705 \u5df2\u5b8c\u6210 6/10 \u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 \u2705 \u5df2\u5b8c\u6210 -/10 <p>\u9009\u62e9\u4e00\u4e2a\u4e13\u9898\u5f00\u59cb\u5b66\u4e60\u3002</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/","title":"\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/#_2","title":"\u6761\u76ee","text":"\u6761\u76ee \u8bf4\u660e \u9898\u76ee \u8bbe\u8ba1\u9898\u76ee\u548c\u573a\u666f \u63d0\u793a \u4ece\u54ea\u4e9b\u65b9\u9762\u8003\u8651 \u7b54\u6848 \u5b8c\u6574\u7b54\u6848 \u8584\u5f31\u70b9 \u8584\u5f31\u70b9\u5206\u6790 <p>\u2190 \u8fd4\u56de\u7cfb\u7edf\u8bbe\u8ba1</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%8F%90%E7%A4%BA/","title":"\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 - \u63d0\u793a","text":"\ud83d\udca1 \u5e94\u8be5\u4ece\u54ea\u4e9b\u65b9\u9762\u8003\u8651\uff1f <p>1. \u65e5\u5fd7\u91c7\u96c6\u548c\u4e0a\u62a5</p> <ul> <li>SDK \u5982\u4f55\u8bbe\u8ba1\uff1f\uff08\u5185\u5b58\u7f13\u51b2\u3001\u5f02\u6b65\u63a8\u9001\uff09</li> <li>\u7f51\u7edc\u4f20\u8f93\u7528\u4ec0\u4e48\u534f\u8bae\uff1f\uff08MQTT\uff1fHTTP\uff1f\uff09</li> <li>\u670d\u52a1\u7aef\u5982\u4f55\u63a5\u6536\uff1f\uff08Kafka\uff1f\u76f4\u63a5\u843d\u5e93\uff1f\uff09</li> </ul> <p>2. \u65e5\u5fd7\u5b58\u50a8</p> <ul> <li>\u65f6\u5e8f\u6570\u636e\u5e93 vs MySQL vs \u5176\u4ed6\uff1f</li> <li>\u8868\u7ed3\u6784\u600e\u4e48\u8bbe\u8ba1\uff1f</li> <li>\u7d22\u5f15\u600e\u4e48\u5efa\uff1f</li> <li>\u6570\u636e\u751f\u547d\u5468\u671f\u600e\u4e48\u7ba1\uff1f</li> </ul> <p>3. \u65e5\u5fd7\u67e5\u8be2</p> <ul> <li>\u51b7\u70ed\u6570\u636e\u600e\u4e48\u5206\u79bb\uff1f</li> <li>\u70ed\u6570\u636e\u7528\u4ec0\u4e48\u7f13\u5b58\uff1f</li> <li>\u67e5\u8be2\u5165\u53e3\u600e\u4e48\u8def\u7531\uff1f</li> </ul> <p>4. \u9ad8\u5e76\u53d1\u573a\u666f</p> <ul> <li>10\u4e07/\u79d2\u5199\u5165\u600e\u4e48\u6297\u4f4f\uff1f</li> <li>\u9700\u8981\u96c6\u7fa4\u5417\uff1f</li> <li>\u6d88\u8d39\u8005\u600e\u4e48\u8bbe\u8ba1\uff1f</li> </ul> <p>\u2190 \u8fd4\u56de\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 | \u9898\u76ee \u2192 | \u7b54\u6848 \u2192</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/","title":"\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 - \u7b54\u6848","text":"\ud83d\udcdd \u5b8c\u6574\u7b54\u6848 <p>\u2190 \u8fd4\u56de\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 | \u9898\u76ee \u2192 | \u63d0\u793a \u2192</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_1","title":"\u6574\u4f53\u67b6\u6784","text":"<p><code>App(SDK) \u2192 Kafka \u2192 \u6d88\u8d39\u8005 \u2192 ClickHouse\uff08\u51b7\u6570\u636e\uff09               \u2193           \u2193            Redis \u2190 ZSET\uff08\u70ed\u6570\u636e\uff09               \u2193          \u67e5\u8be2\u5165\u53e3(\u8def\u7531\u5c42)</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_2","title":"\u65e5\u5fd7\u683c\u5f0f","text":"<p><code>json {   \"topic\": \"error\",   \"business\": \"payment\",   \"user_id\": \"u12345\",   \"level\": \"error\",   \"module\": \"OrderService\",   \"file\": \"OrderController.m\",   \"line\": 128,   \"msg\": \"order create failed\",   \"timestamp\": 1710000000 }</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#kafka","title":"Kafka \u8bbe\u8ba1","text":"<p>Topic \u5212\u5206\uff1a\u6309\u65e5\u5fd7\u7ea7\u522b\uff0c\u5206 3 \u4e2a topic</p> <ul> <li><code>log-error</code></li> <li><code>log-warn</code></li> <li><code>log-info</code></li> </ul> <p>\u6d88\u8d39\u8005\u6839\u636e\u65e5\u5fd7\u7684 <code>business</code> \u5b57\u6bb5\u8def\u7531\u5230\u4e0d\u540c\u7684\u5e93\u8868\u3002</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#clickhouse","title":"ClickHouse \u8868\u7ed3\u6784","text":"<p><code>sql CREATE TABLE guild_log.log_error_payment (     timestamp     DateTime64(3),     user_id       String,     level         String,     module        String,     file          String,     line          UInt32,     msg           String ) ENGINE = MergeTree() PARTITION BY toYYYYMM(timestamp) ORDER BY (timestamp, user_id) TTL timestamp + INTERVAL 30 DAY;</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#redis-zset","title":"Redis ZSET \u70ed\u6570\u636e","text":"<p>```python</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#key-logbusinesslevelrecent","title":"Key: log:{business}:{level}:recent","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#ttl-115","title":"TTL: 1\u5c0f\u65f6~1.5\u5c0f\u65f6\u968f\u673a\uff0c\u9632\u6b62\u96ea\u5d29","text":"<p>TTL = 3600 + random.randint(0, 1800) redis.zadd(\"log:payment:error:recent\", {json: ts}) ```</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_3","title":"\u51b7\u70ed\u6570\u636e\u8def\u7531","text":"<p><code>python if \u67e5\u8be2\u65f6\u95f4\u8303\u56f4.end &lt; now - 1\u5c0f\u65f6:     # \u5168\u662f\u51b7\u6570\u636e\uff0c\u67e5ClickHouse elif \u67e5\u8be2\u65f6\u95f4\u8303\u56f4.start &gt;= now - 1\u5c0f\u65f6:     # \u5168\u662f\u70ed\u6570\u636e\uff0c\u67e5Redis else:     # \u8de8\u51b7\u70ed\uff0c\u4e24\u8005\u90fd\u67e5\u518d\u5408\u5e76</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_4","title":"\u53cc\u5199\u4e00\u81f4\u6027","text":"<p>Redis \u548c ClickHouse \u65e0\u6cd5\u4fdd\u8bc1\u5f3a\u4e00\u81f4\uff0c\u53ea\u80fd\u6700\u7ec8\u4e00\u81f4\uff1a</p> <ul> <li>\u5931\u8d25\u65f6\u8bb0\u5f55\u8865\u507f\u961f\u5217</li> <li>\u4e24\u4e2a\u90fd\u5931\u8d25\u5219\u5165DLQ\u62a5\u8b66</li> </ul>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E8%96%84%E5%BC%B1%E7%82%B9/","title":"\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 - \u8584\u5f31\u70b9","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E8%96%84%E5%BC%B1%E7%82%B9/#_1","title":"\u8584\u5f31\u70b9\u5206\u6790","text":"\u8584\u5f31\u70b9 \u8bf4\u660e \u5b58\u50a8\u5c42\u7ec6\u8282 \u65f6\u5e8f\u6570\u636e\u5e93\u9009\u578b\u3001MergeTree\u5f15\u64ce\u3001PARTITION BY\u3001ORDER BY\u3001TTL Redis \u6570\u636e\u7ed3\u6784 ZSET vs String/Hash\u3001SCORE\u6392\u5e8f\u3001ZRANGEBYSCORE\u8303\u56f4\u67e5\u8be2 \u67e5\u8be2\u8def\u7531\u903b\u8f91 \u51b7\u70ed\u6570\u636e\u5224\u65ad\u3001\u8de8\u51b7\u70ed\u5408\u5e76\u3001\u6309\u65f6\u95f4\u6392\u5e8f \u53cc\u5199\u4e00\u81f4\u6027 \u5f3a\u4e00\u81f4 vs \u6700\u7ec8\u4e00\u81f4\u3001\u8865\u507f\u6a21\u5f0f\u3001DLQ \u7f13\u5b58\u95ee\u9898 \u7a7f\u900f/\u51fb\u7a7f/\u96ea\u5d29\u7684\u573a\u666f\u5316\u89e3\u51b3\u65b9\u6848 \u8fd0\u7ef4\u76d1\u63a7 Consumer lag\u3001\u544a\u8b66\u3001\u6545\u969c\u68c0\u6d4b"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E8%96%84%E5%BC%B1%E7%82%B9/#_2","title":"\u9700\u8981\u52a0\u5f3a\u7684\u65b9\u5411","text":"<ol> <li>ClickHouse \u6df1\u5165\u5b66\u4e60\uff1aMergeTree \u5f15\u64ce\u539f\u7406\u3001\u5206\u533a\u548c\u6392\u5e8f\u952e\u7684\u533a\u522b\u3001TTL \u8bbe\u7f6e\u6280\u5de7</li> <li>Redis ZSET\uff1a\u6709\u5e8f\u96c6\u5408\u7684\u5e95\u5c42\u5b9e\u73b0\u3001score \u6392\u5e8f\u3001\u8303\u56f4\u67e5\u8be2\u547d\u4ee4</li> <li>Kafka \u6d88\u8d39\u8005\u8bbe\u8ba1\uff1aRebalance \u673a\u5236\u3001Consumer Group\u3001 offset \u7ba1\u7406</li> <li>\u5206\u5e03\u5f0f\u4e00\u81f4\u6027\uff1aCAP \u7406\u8bba\u3001\u6700\u7ec8\u4e00\u81f4\u6027\u5b9e\u73b0\u3001\u8865\u507f\u4e8b\u52a1</li> </ol> <p>\u2190 \u8fd4\u56de\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%97%A5%E5%BF%97%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E9%A2%98%E7%9B%AE/","title":"\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 - \u9898\u76ee","text":"<p>\u573a\u666f - \u6536\u96c6\u5ba2\u6237\u7aef App \u64cd\u4f5c\u65e5\u5fd7 - \u65e5\u6d3b 1000\u4e07\u6761/\u5929 - N \u4e2a\u4e1a\u52a1\u7ebf\u5171\u7528\u7cfb\u7edf - \u9700\u8981\u6309\u65f6\u95f4\u8303\u56f4\u67e5\u8be2</p> <p>\u8bf7\u8bbe\u8ba1\uff1a 1. \u65e5\u5fd7\u91c7\u96c6\u548c\u4e0a\u62a5\u65b9\u6848 2. \u65e5\u5fd7\u5b58\u50a8\u65b9\u6848 3. \u65e5\u5fd7\u67e5\u8be2\u5c55\u793a\u65b9\u6848</p> <p>\u8bc4\u4f30\u7ef4\u5ea6\uff1a - \u53ef\u6269\u5c55\u6027 - \u53ef\u9760\u6027 - \u6027\u80fd - \u6210\u672c</p> <p>\u2190 \u8fd4\u56de\u65e5\u5fd7\u7cfb\u7edf\u8bbe\u8ba1 | \u63d0\u793a \u2192</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/","title":"\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/#_2","title":"\u6761\u76ee","text":"\u6761\u76ee \u8bf4\u660e \u9898\u76ee \u8bbe\u8ba1\u9898\u76ee\u548c\u573a\u666f \u63d0\u793a \u4ece\u54ea\u4e9b\u65b9\u9762\u8003\u8651 \u7b54\u6848 \u5b8c\u6574\u7b54\u6848 \u8584\u5f31\u70b9 \u8584\u5f31\u70b9\u5206\u6790 <p>\u2190 \u8fd4\u56de\u7cfb\u7edf\u8bbe\u8ba1</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E6%8F%90%E7%A4%BA/","title":"\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 - \u63d0\u793a","text":"\ud83d\udca1 \u5e94\u8be5\u4ece\u54ea\u4e9b\u65b9\u9762\u8003\u8651\uff1f <p>1. \u7f13\u5b58\u67b6\u6784</p> <ul> <li>\u5ba2\u6237\u7aef\u7f13\u5b58 vs \u670d\u52a1\u7aef\u7f13\u5b58\uff1f</li> <li>\u672c\u5730\u7f13\u5b58\u7528\u4ec0\u4e48\uff1f\uff08LRU\uff1f\u5bb9\u91cf\u9650\u5236\uff1f\uff09</li> <li>Redis \u591a\u5b9e\u4f8b\u8fd8\u662f\u96c6\u7fa4\uff1f</li> </ul> <p>2. Key \u8bbe\u8ba1</p> <ul> <li>\u6309\u4ec0\u4e48\u7ef4\u5ea6\u7ec4\u7ec7\uff1f</li> <li>\u547d\u540d\u89c4\u8303\uff1f</li> </ul> <p>3. \u6570\u636e\u66f4\u65b0</p> <ul> <li>\u8bfb\u6d41\u7a0b\u662f\u4ec0\u4e48\uff1f</li> <li>\u5199\u6d41\u7a0b\u662f\u4ec0\u4e48\uff1f</li> <li>\u5ba2\u6237\u7aef\u7f13\u5b58\u600e\u4e48\u4fdd\u8bc1\u4e00\u81f4\u6027\uff1f\uff08\u7248\u672c\u53f7\uff1f\u63a8\u9001\uff1f\uff09</li> </ul> <p>4. \u7f13\u5b58\u95ee\u9898</p> <ul> <li>\u7a7f\u900f\uff1a\u67e5\u8be2\u4e0d\u5b58\u5728\u7684\u6570\u636e</li> <li>\u51fb\u7a7f\uff1a\u70ed\u70b9 key \u8fc7\u671f\u77ac\u95f4</li> <li>\u96ea\u5d29\uff1a\u5927\u91cf key \u540c\u65f6\u8fc7\u671f</li> </ul> <p>5. \u5927\u4fc3\u573a\u666f</p> <ul> <li>10\u4e07 QPS \u600e\u4e48\u6297\u4f4f\uff1f</li> <li>\u9700\u8981\u9884\u70ed\u5417\uff1f</li> <li>Redis Cluster vs \u4ee3\u7406\u6a21\u5f0f\uff1f</li> </ul> <p>\u2190 \u8fd4\u56de\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 | \u9898\u76ee \u2192 | \u7b54\u6848 \u2192</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/","title":"\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 - \u7b54\u6848","text":"\ud83d\udcdd \u5b8c\u6574\u7b54\u6848 <p>\u2190 \u8fd4\u56de\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 | \u9898\u76ee \u2192 | \u63d0\u793a \u2192</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_1","title":"\u6574\u4f53\u67b6\u6784","text":"<p>``` \u5ba2\u6237\u7aef\uff08App/Web\uff09     \u2193 \u672c\u5730\u7f13\u5b58\uff08LRU/\u5bb9\u91cf\u9650\u5236\uff09</p> <p>\u670d\u52a1\u7aef\uff1a   \u8bfb\u64cd\u4f5c \u2192 Redis \u2192 (miss) \u2192 \u6570\u636e\u5e93   \u5199\u64cd\u4f5c \u2192 \u6570\u636e\u5e93 \u2192 (\u540c\u6b65/\u5f02\u6b65) \u2192 Redis ```</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#key","title":"Key \u8bbe\u8ba1","text":"<p><code>product:detail:{product_id} session:{user_id} cart:{user_id}</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_2","title":"\u5ba2\u6237\u7aef\u7f13\u5b58\u4e00\u81f4\u6027","text":"<p>\u7248\u672c\u53f7\u673a\u5236\uff1a</p> <p>```json // \u670d\u52a1\u7aef {\"id\": \"p123\", \"version\": 56, \"price\": 99.9}</p> <p>// \u5ba2\u6237\u7aef\u7f13\u5b58 {\"id\": \"p123\", \"version\": 55, \"cached_price\": 98.0} ```</p> <p>\u5ba2\u6237\u7aef\u8bf7\u6c42 <code>GET /product/p123/version</code>\uff0c\u53d1\u73b0\u7248\u672c\u4f4e\u4e8e\u670d\u52a1\u7aef\uff0c\u4e0b\u62c9\u5b8c\u6574\u6570\u636e\u66f4\u65b0\u672c\u5730\u7f13\u5b58\u3002</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_3","title":"\u7a7f\u900f/\u51fb\u7a7f/\u96ea\u5d29","text":"<p>\u7a7f\u900f\uff1a\u7f13\u5b58\u7a7a\u503c</p> <p><code>python if not found:     redis.setex(key, short_ttl, \"NULL\")</code></p> <p>\u51fb\u7a7f\uff1a\u70ed\u70b9\u6c38\u4e0d\u8fc7\u671f + \u4e92\u65a5\u9501</p> <p>```python</p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#a","title":"\u65b9\u6848A\uff1a\u6c38\u4e0d\u8fc7\u671f\uff0c\u5f02\u6b65\u5237\u65b0","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#b","title":"\u65b9\u6848B\uff1a\u4e92\u65a5\u9501\uff0c\u53ea\u5141\u8bb8\u4e00\u4e2a\u8bf7\u6c42\u56de\u6e90","text":"<p>```</p> <p>\u96ea\u5d29\uff1a\u968f\u673a TTL</p> <p><code>python TTL = base_ttl + random.randint(0, 1800)</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#redis","title":"Redis \u96c6\u7fa4","text":"\u573a\u666f \u63a8\u8350 &lt;50\u4e07 QPS Redis Cluster &gt;50\u4e07 QPS / \u6279\u91cf\u64cd\u4f5c\u591a Twemproxy/Codis"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%AD%94%E6%A1%88/#_4","title":"\u5927\u4fc3\u9884\u70ed","text":"<p><code>python def preheat():     products = get_promotion_products()  # 10\u4e07\u4e2a     for batch in chunk(products, 1000):         data = db.batch_get(batch)         redis.pipeline().setex(data)         time.sleep(5)  # \u63a7\u5236\u901f\u5ea6</code></p>"},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E8%96%84%E5%BC%B1%E7%82%B9/","title":"\u7f13\u5b58\u7cfb\u7edf\u8bbe\u8ba1 - \u8584\u5f31\u70b9","text":""},{"location":"%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E7%BC%93%E5%AD%98%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1/%E8%96%84%E5%BC%B1%E7%82%B9/#_1","title":"\u8584\u5f31\u70b9\u5206\u6790","text":"\u8584\u5f31\u70b9 \u8bf4\u660e Redis \u6570\u636e\u7ed3\u6784\u9009\u578b \u8303\u56f4\u67e5\u8be2\u7528 ZSET\uff0c\u4e0d\u662f String/Hash \u5ba2\u6237\u7aef\u7f13\u5b58\u4e00\u81f4\u6027 \u7248\u672c\u53f7\u673a\u5236\u662f\u6807\u51c6\u505a\u6cd5\uff0c\u4f46\u9700\u8981\u670d\u52a1\u7aef\u914d\u5408 \u53cc\u5199\u4e00\u81f4\u6027 \u6ca1\u6709\u771f\u6b63\u7684\u4e8b\u52a1\uff0c\u6b63\u786e\u7684\u662f\"\u8865\u507f\u6a21\u5f0f\" \u7f13\u5b58\u95ee\u9898\u573a\u666f\u5316 \u7a7f\u900f/\u51fb\u7a7f/\u96ea\u5d29\u7684\u89e3\u51b3\u65b9\u6848\u548c\u9002\u7528\u573a\u666f Redis \u96c6\u7fa4 Cluster vs \u4ee3\u7406\u6a21\u5f0f\u7684\u9009\u62e9\u4f9d\u636e \u9884\u70ed\u7b56\u7565 \u901f\u5ea6\u63a7\u5236\u3001\u9a8c\u8bc1\u673a\